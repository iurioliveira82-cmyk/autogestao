rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, name, email, role (admin, employee), createdAt
    //
    // Collection: clients
    // Fields: name, phone, email, status (active, inactive), createdAt
    //
    // Collection: vehicles
    // Fields: plate, brand, model, year, color, km, clientId, createdAt
    //
    // Collection: services
    // Fields: name, price, averageTime
    //
    // Collection: serviceOrders
    // Fields: clientId, vehicleId, services (list), status, photosBefore, photosAfter, observations, totalValue, discount, paymentMethod, createdAt, updatedAt
    //
    // Collection: appointments
    // Fields: clientId, vehicleId, startTime, endTime, status
    //
    // Collection: inventory
    // Fields: name, quantity, minQuantity, price, cost, supplierId, category
    //
    // Collection: suppliers
    // Fields: name, cnpj, phone, email, address, category, status, createdAt
    //
    // Collection: stockMovements
    // Fields: itemId, type (in, out), quantity, reason, date, userId, cost
    //
    // Collection: transactions
    // Fields: type (in, out), value, category, description, date, status (paid, pending), paymentMethod, relatedOSId
    //
    // Collection: resaleVehicles
    // Fields: brand, model, year, buyPrice, sellPrice, status, createdAt
    //
    // Collection: fiscalRecords
    // Fields: type (nfe, nfse, cupom), number, series, date, value, taxValue, status (emitted, cancelled, pending), relatedOSId, clientId, xmlUrl, pdfUrl, observations, createdAt

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "iurioliveira82@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isEmployee() {
      return isAuthenticated() && 
        (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee'));
    }

    function hasPermission(module, action) {
      return isAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions[module][action] == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'name', 'email', 'role', 'createdAt', 'permissions', 'updatedAt']) &&
             data.uid is string && data.name is string && data.email is string &&
             data.role in ['admin', 'employee'] &&
             (!('permissions' in data) || data.permissions is map);
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'phone', 'status']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() >= 8 &&
             data.status in ['active', 'inactive'];
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['plate', 'brand', 'model', 'clientId']) &&
             data.plate is string && data.plate.size() > 0 &&
             data.brand is string && data.model is string &&
             data.clientId is string;
    }

    function isValidOS(data) {
      return data.keys().hasAll(['clientId', 'vehicleId', 'status', 'totalValue']) &&
             data.status in ['waiting', 'in-progress', 'finished', 'cancelled'];
    }

    function isValidInventory(data) {
      return data.keys().hasAll(['name', 'quantity']) &&
             data.name is string && data.quantity is number;
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['name', 'status']) &&
             data.name is string && data.status in ['active', 'inactive'];
    }

    function isValidStockMovement(data) {
      return data.keys().hasAll(['itemId', 'type', 'quantity', 'date', 'userId']) &&
             data.type in ['in', 'out'] && data.quantity is number && data.userId == request.auth.uid;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'value', 'category', 'date', 'status']) &&
             data.type in ['in', 'out'] && data.value is number && data.status in ['paid', 'pending'];
    }

    function isValidFiscalRecord(data) {
      return data.keys().hasAll(['type', 'number', 'date', 'value', 'status', 'clientId']) &&
             data.type in ['nfe', 'nfse', 'cupom'] &&
             data.status in ['emitted', 'cancelled', 'pending'] &&
             data.value is number &&
             data.clientId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == 'employee' || isAdmin())) ||
                    (isAdmin() && isValidUser(request.resource.data));
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin() || isOwner(uid);
    }

    match /clients/{clientId} {
      allow read: if isEmployee();
      allow create, update: if isEmployee() && isValidClient(request.resource.data);
      allow delete: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if isEmployee();
      allow create, update: if isEmployee() && isValidVehicle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    match /serviceOrders/{osId} {
      allow read: if isEmployee();
      allow create: if isEmployee() && isValidOS(request.resource.data);
      allow update: if isEmployee() && isValidOS(request.resource.data) && (resource.data.status != 'finished' || isAdmin());
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    match /inventory/{itemId} {
      allow read: if hasPermission('stock', 'view');
      allow create, update: if hasPermission('stock', 'create') && isValidInventory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /suppliers/{supplierId} {
      allow read: if hasPermission('suppliers', 'view');
      allow create, update: if hasPermission('suppliers', 'create') && isValidSupplier(request.resource.data);
      allow delete: if isAdmin();
    }

    match /stockMovements/{movementId} {
      allow read: if hasPermission('stock', 'view');
      allow create: if hasPermission('stock', 'create') && isValidStockMovement(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin();
      allow create: if isEmployee() && isValidTransaction(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /resaleVehicles/{resaleId} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    match /fiscalRecords/{fiscalId} {
      allow read: if hasPermission('fiscal', 'view');
      allow create: if hasPermission('fiscal', 'create') && isValidFiscalRecord(request.resource.data);
      allow update: if hasPermission('fiscal', 'edit') && isValidFiscalRecord(request.resource.data);
      allow delete: if hasPermission('fiscal', 'delete');
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
